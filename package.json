{
  "name": "i18n-sharpen",
  "version": "0.2.0",
  "description": "A type-safe and configuration-driven i18n validator, extractor, and pruner CLI tool.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "i18n-sharpen": "./dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "prepare": "simple-git-hooks"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "validator",
    "extractor",
    "pruner",
    "cli",
    "translation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.12.7",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "lint-staged": "^17.0.5",
    "prettier": "3.7.4",
    "simple-git-hooks": "^2.13.1",
    "tsup": "^8.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^1.5.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "simple-git-hooks"
    ]
  }
}
